# localcamera-service — local settings
# Copy to config.env and fill in. config.env is gitignored (it holds your wifi password).
#   cp config.env.example config.env   then edit config.env

# --- WiFi (the camera is 2.4 GHz + WPA2 only) ---
WIFI_SSID="Los Santos Customs"
WIFI_PASSWORD="your-wifi-password-here"

# --- Camera on the LAN ---
# yi-hack-v3 uses DHCP. Fill CAMERA_IP after you locate it (scripts/find-camera.sh).
CAMERA_IP="192.168.0.143"
LAN_SUBNET="192.168.0"      # first 3 octets of your LAN, used by scripts/find-camera.sh
